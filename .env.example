# StayEasy environment variables — copy to `.env` and fill in.
# Every feature below is OFF (no-op) until its variable is set, so the app
# ships clean without any of these. `.env` is gitignored; never commit real keys.

# ── Business model master switch ───────────────────────────────────
# StayEasy launches as a pure audience/content site first. All monetization
# surfaces — discount vouchers, ads, "Sponsored" badges, and the consumer
# member sign-in — are HIDDEN by default. Set to `true` to turn the whole
# business model back on once you're ready. (Off/empty = content-only.)
VITE_ENABLE_BM=

# ── Google Analytics 4 ─────────────────────────────────────────────
# Measurement ID from GA4 Admin → Data streams → Web (looks like G-XXXXXXXXXX).
# When set: SPA page_view on every route change, plus intent events
# (hotel_view, voucher_unlock, voucher_download, official_site_click, contact_click).
VITE_GA_ID=

# ── Google Sign-In (guest login) ───────────────────────────────────
# OAuth Web client ID from Google Cloud console (…apps.googleusercontent.com).
# When set: the voucher unlock + /signin use real Google instead of the demo identity.
VITE_GOOGLE_CLIENT_ID=

# ── Google AdSense ─────────────────────────────────────────────────
# Publisher ID (ca-pub-XXXXXXXXXXXXXXXX). When set: ad slots render.
VITE_ADSENSE_CLIENT=

# ── Backend API (parked) ───────────────────────────────────────────
# Base URL of the Fastify backend (server/). When set: the repo layer can
# read from the API instead of the in-browser mock.
VITE_API_URL=

# ── Contact ────────────────────────────────────────────────────────
# Public contact address shown in legal/footer (defaults to a placeholder).
VITE_CONTACT_EMAIL=

{
  "name": "stayeasy-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "StayEasy Vietnam backend — implements src/api/contract.ts. Catalog is DB-backed via Prisma; admin numbers derive from the same data.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push --skip-generate && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.20.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
